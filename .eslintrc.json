{
    "env": {
        "browser": true,
        "jquery": true
    },
    "globals": {
        "BpmnJS": "readonly",
        "DmnJS": "readonly",
        "DmnJSViewer": "readonly"
    },
    "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "script"
    },
    "ignorePatterns": ["vendor/**"],
    "rules": {
        "no-unused-vars": "warn",
        "no-undef": "error",
        "eqeqeq": "warn",
        "no-console": ["warn", { "allow": ["warn", "error"] }],
        "curly": "warn",
        "no-eval": "error",
        "no-implied-eval": "error"
    }
}
